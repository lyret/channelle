# Channelle - Environment Configuration Example
# ============================================================================
# Copy this file to .env and modify the values as needed for your deployment.
# All environment variables are optional unless marked as [REQUIRED].
# CLI flags will override environment variables when provided.

# ============================================================================
# SHOW CONFIGURATION
# ============================================================================

# Show name for this deployment
# CLI flag: --name
# Optional: Yes, defaults to empty string
# SHOW_NAME=My Performance Stage

# Password for password-protected shows
# CLI flag: --password
# Optional: Yes, defaults to empty string (public show)
# SHOW_PASSWORD=secret_password_123

# Password for theater mode authentication
# CLI flag: --theaterPassword
# Optional: Yes, defaults to "admin"
# THEATER_PASSWORD=secure_theater_password

# Show ID to initialize stage with (stage mode only)
# CLI flag: --showId
# Optional: Yes, no default
# SHOW_ID=1

# ============================================================================
# RUNTIME CONFIGURATION
# ============================================================================

# Enable production mode (affects security, logging, and performance)
# CLI flag: --production
# Optional: Yes, defaults to false (or true if NODE_ENV=production)
# PRODUCTION=false

# Server port number
# CLI flag: --port
# Optional: Yes, defaults to 3000
# PORT=3000

# Enable theater mode (management interface)
# CLI flag: --theater
# Optional: Yes, defaults to false (stage mode)
# THEATER=false

# Enable debug mode (enables Node.js debugger support)
# CLI flag: --debug
# Optional: Yes, defaults to false
# DEBUG=false

# Enable local network access (loopback interface)
# CLI flag: --local
# Optional: Yes, defaults to true
# LOCAL=true

# Enable LAN network access (local area network)
# CLI flag: --lan
# Optional: Yes, defaults to true
# LAN=true

# Enable WAN network access (wide area network/internet)
# CLI flag: --wan
# Optional: Yes, defaults to production value
# WAN=false

# Enable build mode (generate fresh code bundles)
# CLI flag: --build
# Optional: Yes, defaults to false
# BUILD=false

# Enable watch mode (rebuild on file changes)
# CLI flag: --watch
# Optional: Yes, defaults to false
# WATCH=false

# Enable start mode (launch the server)
# CLI flag: --start
# Optional: Yes, defaults to false
# START=false

# # Unique identifier for this deployment
# CLI flag: --slug
# Optional: Yes, defaults to slugified show name
# SLUG=my-deployment-slug

# ============================================================================
# IPC CONFIGURATION
# ============================================================================

# URL for stage server communication (used only in theater mode)
# CLI flag: --ipcStageUrl
# Optional: Yes, defaults to "http://localhost:3000" for development
# Must match the stage server URL
# IPC_STAGE_URL=http://stage1.channelle.se

# Secret key for theater-stage IPC communication
# CLI flag: --ipcSecret
# Optional: Yes, defaults to "channelle-ipc-secret"
# Must be the same for both theater and stage servers
# IPC_SECRET=your-secret-key-here


# ============================================================================
# USAGE EXAMPLES
# ============================================================================

# Development stage server:
# PORT=3000
# DEBUG=true
# VERBOSE=true

# Production stage server:
# PRODUCTION=true
# PORT=80
# SHOW_NAME=Main Performance
# WAN=true
# IPC_SECRET=your-secure-ipc-key
